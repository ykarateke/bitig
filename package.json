{
  "name": "@erdemayaz/bitig",
  "version": "1.0.2",
  "description": "TypeScript OOP-based book compiling and formatting package with Puppeteer PDF generation and AI agent metadata support.",
  "main": "dist/index.js",
  "repository": "erdemayaz/bitig",
  "types": "dist/index.d.ts",
  "bin": {
    "bitig": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:cov": "jest --coverage",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.json\" \"README.md\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": "prettier --write",
    "*.{json,md}": "prettier --write"
  },
  "keywords": [
    "book",
    "markdown",
    "pdf",
    "compiler",
    "ai",
    "metadata",
    "typescript"
  ],
  "author": "Erdem Ayaz",
  "license": "MIT",
  "dependencies": {
    "marked": "^12.0.1",
    "puppeteer": "^22.11.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
